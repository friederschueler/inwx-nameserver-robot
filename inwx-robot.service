[Unit]
Description=INWX IPv6 DNS Robot
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=inwx-robot
Group=inwx-robot
WorkingDirectory=/opt/inwx-robot
ExecStart=/opt/inwx-robot/venv/bin/python /opt/inwx-robot/main.py
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/inwx-robot

[Install]
WantedBy=multi-user.target
